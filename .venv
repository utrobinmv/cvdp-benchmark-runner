#!/usr/bin/env bash
# Активирует виртуальное окружение cvdp-benchmark-runner
#
# ИСПОЛЬЗОВАНИЕ:
#   source .venv      (или . .venv)
# НЕ запускать как:  ./venv  -- это создаст подпроцесс, окружение сразу исчезнет!

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "Ошибка: запускай через source:  source .venv"
    exit 1
fi

source ~/workspace/venvs/cvdp-benchmark-runner/default/bin/activate
